# === Telegram User Account (для чтения групп) ===
# Получить на https://my.telegram.org → API Development Tools
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890
TG_PHONE=+380991234567

# === Telegram Bot (для отправки отчётов) ===
# Создать бота через @BotFather → /newbot
BOT_TOKEN=1234567890:ABCDefghIJKlmnopQRSTuvwxyz

# === Твой личный Chat ID (куда слать отчёты) ===
# Узнать: напиши боту @userinfobot
REPORT_CHAT_ID=123456789

# === Claude API ===
# https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-...

# === Группы для мониторинга ===
# Username группы (начинается с @) или числовой ID
# Несколько — через запятую
MONITOR_GROUPS=@your_seller_group
